PICSART_API_KEY=
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/purzel
HF_TOKEN=
REPLICATE_API_TOKEN=your_token_here

# Sketchfab (optional): API-Token für Upload/Import von 3D-Modellen
# Ohne Token werden Sketchfab-Features im Frontend ausgeblendet.
SKETCHFAB_API_TOKEN=

# CORS: kommagetrennte Liste erlaubter Ursprünge (Standard: localhost:5173)
# Beispiel für mehrere Ursprünge: http://localhost:5173,https://meine-app.example.com
CORS_ORIGINS=http://localhost:5173

# UniRig Lokal (optional, für GPU-Inferencing ohne HF Space)
# Checkpoint herunterladen (einmalig, ~5 GB):
#   huggingface-cli download VAST-AI/UniRig --local-dir ./models/unirig/
# UniRig-Repo klonen für Inferenz-Skripte:
#   git clone https://github.com/VAST-AI-Research/UniRig ./unirig/
UNIRIG_MODEL_PATH=./models/unirig/
UNIRIG_REPO_PATH=./unirig/

# Blender Rigify (lokal, headless) — für blender-rigify Provider
# Standard: blender (aus PATH). Überschreibbar für custom Pfade.
BLENDER_EXECUTABLE=blender
